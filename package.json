{
  "name": "image-to-dxf",
  "version": "1.0.0",
  "description": "AI-powered image to DXF CAD converter",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite client",
    "build": "vite build client --outDir ../dist/public && echo 'Build complete'",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@tarikjabiri/dxf": "^2.8.9",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.3.5"
  }
}
